{
  "expo": {
    "name": "GrowUp",
    "slug": "growup",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "growup",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090F"
    },
    "ios": { "supportsTablet": false, "bundleIdentifier": "com.growup.app" },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#09090F"
      },
      "package": "com.growup.app"
    },
    "plugins": [
      "expo-router",
      ["expo-image-picker", {
        "photosPermission": "GrowUp needs photo access to share posts"
      }]
    ],
    "experiments": { "typedRoutes": true }
  }
}