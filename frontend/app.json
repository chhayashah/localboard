{
  "expo": {
    "name": "LocalBoard",
    "slug": "localboard",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "localboard",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090F"
    },
    "ios": { "supportsTablet": false },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#09090F"
      },
      "package": "com.localboard.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "LocalBoard ko photos access chahiye post karne ke liye"
        }
      ]
    ],
    "experiments": { "typedRoutes": true }
  }
}
